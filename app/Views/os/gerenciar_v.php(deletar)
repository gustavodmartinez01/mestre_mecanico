<script>
    // AJAX para atualizar checklist sem recarregar
    function atualizarChecklist(itemId, status) {
        $.post('<?= base_url('os/atualizar_item_checklist') ?>', {
            item_id: itemId,
            status: status
        }, function(res) {
            if(res.status !== 'success') alert('Erro ao salvar checklist.');
        });
    }

    function confirmarFinalizacao() {
        if(confirm("Deseja realmente finalizar esta OS? Isso gerará o financeiro e registrará a data de fechamento.")) {
            window.location.href = "<?= base_url("os/finalizar/{$os['id']}") ?>";
        }
    }
</script>
